specification {
  element actor
  element softwareSystem
  element externalSystem
  element container
  element logicalComponent
  element dataStore
  element computeNode
  element monitoredProcess
}

model {
  actor user 'User' {
    description 'Retail investor. Reads daily journal, reviews reports, monitors dashboard.'
  }

  externalSystem alphaLake 'Alpha-Lake' {
    description 'Point-in-time data plane for bars, fundamentals, insider, earnings, attention. Consumed over REST API.'
    technology 'REST API (httpx)'
  }

  externalSystem llmProvider 'LLM Provider' {
    description 'OpenAI-compatible chat API (OpenAI or OpenRouter). Generates narrated journal and concept card explanations. Never in decision path.'
    technology 'OpenAI-compatible REST API'
  }

  softwareSystem alphaQuant 'Alpha-Quant' {
    description 'Deterministic, daily-cadence, long-only equity system. Internal paper engine. LLM-powered narration.'

    container cli 'CLI' {
      description 'Command-line interface. Entry point for run, journal, ask, report, status, halt, backup.'
      technology 'typer'
    }

    container pipelineEngine 'Pipeline Engine' {
      description 'Daily orchestrator. Reads decision panel from Alpha-Lake, runs policy modules, executes risk/fill/sizing, persists to store.'
      technology 'run_v2() — single pipeline function'

      logicalComponent sessionRunner 'run_v2()' {
        description 'The sole pipeline function. Sequence: panel read → regime → risk → evaluate → rank → fill → mark → consistency → persist.'
      }

      logicalComponent alphaLakeReadPort 'AlphaLakeReadPort' {
        description 'Single Protocol interface to Alpha-Lake. health(), read_contract(), read_universe(), read_decision_panel().'
        technology 'Protocol'
      }

      logicalComponent decisionContext 'DecisionContext' {
        description 'Extracted-facts facade over DecisionPanel. Policy modules receive this, not raw panel data.'
        technology 'dataclass'
      }
    }

    container policyModules 'Policy Modules' {
      description '7 policy modules, each evaluating on DecisionContext. Pure functions — no I/O, no imports from adapters.'
      technology 'plain Python'

      logicalComponent regimePolicy 'Regime Policy (M2)' {
        description 'SPY EMA50/200 + VIX → RISK_ON / CAUTION / RISK_OFF.'
        technology 'plain Python'
      }

      logicalComponent technicalPolicy 'Technical Policy (M3)' {
        description 'Composite score from trend + RSI + MACD + momentum + volume + ATR validation.'
        technology 'plain Python'
      }

      logicalComponent fundamentalPolicy 'Fundamental Policy (M4)' {
        description 'Binary pass/fail: OCF > 0, D/E < sector median, no negative surprises, accruals sane.'
        technology 'plain Python'
      }

      logicalComponent insiderPolicy 'Insider Policy (M5)' {
        description 'Cluster signal: ≥2 officers/directors, ≥$200k net in 30d → score boost.'
        technology 'plain Python'
      }

      logicalComponent attentionPolicy 'Attention Policy (M6)' {
        description 'Mention z-score veto. z > 3 gives 14-day entry block.'
        technology 'plain Python'
      }

      logicalComponent blackoutPolicy 'Earnings Blackout Policy (M7)' {
        description 'No entries within 3 trading days before earnings report.'
        technology 'plain Python'
      }

      logicalComponent compositePolicy 'Composite Policy (M8)' {
        description 'Weighted ranking: 0.6 × technical + 0.25 × momentum + 0.15 × insider. Gates applied first.'
        technology 'plain Python'
      }
    }

    container domainCore 'Domain Core' {
      description 'Pure functions for position sizing, risk management, fill model, ranking, invariants. No I/O.'
      technology 'pydantic'

      logicalComponent positionSizer 'Position Sizer' {
        description 'shares = (equity × 1%) / (2 × ATR). Capped per-position, per-sector, gross. × regime × drawdown.'
      }

      logicalComponent riskEvaluator 'Risk Evaluator' {
        description 'Exit-only: 2× ATR stop, trail after +1R, partial at +2R, 30d time stop, drawdown ladder, daily loss halt.'
      }

      logicalComponent fillEngine 'Fill Engine' {
        description 'Daily-bar fill model: entries at T+1 open + slippage, stops on low/range touch, gaps fill at open. One model for all modes.'
      }

      logicalComponent ranker 'Ranker' {
        description 'Sorts candidates by composite score, enforces max positions, sector limits, liquidity tiebreak.'
      }
    }

    container stateStore 'State Store' {
      description 'CanonicalStore — composite mixin over DuckDB tables. Positions, decisions, orders, fills, events, portfolio snapshots, indicator state.'
      technology 'CanonicalStore (DuckDB)'

      logicalComponent positionStore 'Position Store'
      logicalComponent decisionStore 'Decision Store'
      logicalComponent orderStore 'Order Store'
      logicalComponent eventStore 'Event Store'
      logicalComponent adminStore 'Admin Store'
    }

    container narrator 'LLM Narrator' {
      description 'Reads events from event log, builds NarrationContext, sends to LLM, fact-checks output, generates Markdown journal/reports.'
      technology 'httpx, structlog'
    }

    container dashboard 'Streamlit Dashboard' {
      description 'Read-only monitoring dashboard. Tabs: Portfolio, Risk, Journal, Decisions. Reads from DuckDB only — zero pipeline coupling.'
      technology 'Streamlit'
    }

    container eventLog 'Event Log' {
      description 'Append-only typed events from every pipeline stage. Written to DuckDB (queries) and structlog JSON stream.'
      technology 'DuckDB, structlog'
    }

    dataStore duckDb 'DuckDB State Database' {
      description 'Single-file DuckDB database in data/. All transactional state: positions, decisions, orders, fills, equity curve, events.'
      technology 'DuckDB'
    }

    dataStore configFile 'Config File' {
      description 'config.toml at project root.'
      technology 'TOML'
    }

    dataStore haltFile 'Halt Lockfile' {
      description 'data/.HALT lockfile. Pipeline refuses to run while it exists.'
      technology 'JSON file'
    }

    dataStore fixtureDir 'Fixture Directory' {
      description 'fixtures/v1/. JSON fixture files for replay: health, contract, universe, decision-panel.'
      technology 'JSON files'
    }
  }

  computeNode localMachine 'Local Machine' {
    description 'Single-machine deployment. Developer workstation or headless server.'

    monitoredProcess cliProcess 'CLI Process' {
      description 'Ad-hoc operations. Run, journal, ask, report, status, halt, backup.'
      technology 'typer, Python 3.14+'
    }

    monitoredProcess dashboardProcess 'FastAPI SPA' {
      description 'Operational console. Vanilla JS SPA served by FastAPI on localhost:8501/8099. SSE live updates.'
      technology 'Vanilla JS, FastAPI, Server-Sent Events'
    }
  }

  user -> alphaQuant 'Reads journal, operates dashboard' {
    technology 'CLI, Browser SPA'
  }

  alphaQuant -> alphaLake 'reads decision panel, contract, universe' {
    technology 'AlphaLakeRestClient (httpx)'
  }

  alphaQuant -> llmProvider 'Sends NarrationContext, receives prose' {
    technology 'httpx chat completions API'
  }

  cli -> pipelineEngine 'Dispatches run command'

  pipelineEngine -> alphaLakeReadPort 'Reads panel via adapter'
  pipelineEngine -> policyModules 'Runs M2-M8 evaluation'
  pipelineEngine -> domainCore 'Risk, fill, size, rank'
  pipelineEngine -> eventLog 'Emits events from every stage'
  pipelineEngine -> stateStore 'Persists decisions, fills, events'

  pipelineEngine.alphaLakeReadPort -> alphaLake 'HTTP request'
  pipelineEngine.alphaLakeReadPort -> fixtureDir 'JSON file read (fixture mode)'

  policyModules -> decisionContext 'Extract facts from panel'
  decisionContext -> pipelineEngine 'Receives DecisionPanel'

  domaineCore.fillEngine -> stateStore 'Writes fills, positions'
  domaineCore.riskEvaluator -> stateStore 'Updates position stops/trails'

  stateStore -> duckDb 'SQL writes'
  stateStore -> duckDb 'SQL reads'

  cli -> stateStore 'Reads status, reports'

  narrator -> eventLog 'Reads events for context'
  narrator -> stateStore 'Reads positions, equity'
  narrator -> llmProvider 'Sends context, receives prose'

  dashboard -> duckDb 'Read-only queries'
}
