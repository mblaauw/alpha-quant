            "type": "string"
          },
          "title": "Books",
          "type": "array"
        }
      },
      "title": "ShadowConfig",
      "type": "object"
    },
    "UniverseConfig": {
      "properties": {
        "min_price": {
          "default": 5.0,
          "title": "Min Price",
          "type": "number"
