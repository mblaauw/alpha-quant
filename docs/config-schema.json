  "properties": {
    "config_version": {
      "default": 1,
      "title": "Config Version",
      "type": "integer"
    },
    "bootstrap": {
      "$ref": "#/$defs/BootstrapConfig"
    },
    "data": {
      "$ref": "#/$defs/DataConfig"
    },
    "universe": {
      "$ref": "#/$defs/UniverseConfig"
    },
    "portfolio": {
      "$ref": "#/$defs/PortfolioConfig"
    },
    "paper": {
      "$ref": "#/$defs/PaperConfig"
    },
    "risk": {
      "$ref": "#/$defs/RiskConfig"
    },
    "shadow": {
      "$ref": "#/$defs/ShadowConfig"
    },
    "llm": {
      "$ref": "#/$defs/LLMConfig"
    },
    "education": {
      "$ref": "#/$defs/EducationConfig"
    },
    "connector": {
      "$ref": "#/$defs/ConnectorConfig"
    },
    "eodhd": {
      "$ref": "#/$defs/EODHDConfig"
    },
    "alpaca": {
      "$ref": "#/$defs/AlpacaConfig"
    },
    "dashboard": {
      "$ref": "#/$defs/DashboardConfig"
    }
  },
  "required": [
    "bootstrap",
    "data",
    "universe",
    "portfolio",
    "paper",
    "risk",
    "shadow",
    "llm",
    "education",
    "connector",
    "eodhd",
    "alpaca",
    "dashboard"
  ],
  "title": "AppConfig",
  "type": "object"
