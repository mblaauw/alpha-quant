        "min_adv_usd": {
          "default": 5000000,
          "title": "Min Adv Usd",
          "type": "number"
        },
        "index_base": {
          "default": "sp500_plus_midcap400",
          "title": "Index Base",
          "type": "string"
        }
      },
      "title": "UniverseConfig",
      "type": "object"
    }
