{
  "$defs": {
    "AlpacaConfig": {
      "properties": {
        "api_key": {
          "default": "",
          "format": "password",
          "title": "Api Key",
          "type": "string",
          "writeOnly": true
        },
        "secret_key": {
          "default": "",
          "format": "password",
          "title": "Secret Key",
          "type": "string",
          "writeOnly": true
        },
        "base_url": {
          "default": "https://data.alpaca.markets",
          "title": "Base Url",
          "type": "string"
        }
      },
      "title": "AlpacaConfig",
      "type": "object"
    },
    "BootstrapConfig": {
      "properties": {
        "symbols": {
          "items": {
            "type": "string"
          },
          "title": "Symbols",
          "type": "array"
        },
        "history_years": {
          "default": 3,
          "title": "History Years",
          "type": "integer"
        },
        "include_benchmarks": {
          "default": [
            "SPY",
            "^VIX"
          ],
          "items": {
            "type": "string"
          },
          "title": "Include Benchmarks",
          "type": "array"
        }
      },
      "required": [
        "symbols"
      ],
      "title": "BootstrapConfig",
      "type": "object"
    },
    "ConnectorConfig": {
      "properties": {
        "user_agent": {
          "default": "AlphaQuant/0.1.0 (research project; contact m@mblaauw.dev)",
          "title": "User Agent",
          "type": "string"
        },
        "tokens_per_second": {
          "default": 10.0,
          "title": "Tokens Per Second",
          "type": "number"
        },
        "max_burst": {
          "default": 20.0,
          "title": "Max Burst",
          "type": "number"
        },
        "default_timeout_s": {
          "default": 30.0,
          "title": "Default Timeout S",
          "type": "number"
        }
      },
      "title": "ConnectorConfig",
      "type": "object"
    },
    "DashboardConfig": {
      "properties": {
        "host": {
          "default": "localhost",
          "title": "Host",
          "type": "string"
        },
        "port": {
          "default": 8501,
          "title": "Port",
          "type": "integer"
        },
        "refresh_seconds": {
          "default": 60,
          "title": "Refresh Seconds",
          "type": "integer"
        }
      },
      "title": "DashboardConfig",
      "type": "object"
    },
    "DataConfig": {
      "properties": {
        "mode": {
          "default": "fixture",
          "title": "Mode",
          "type": "string"
        },
        "indicator_state": {
          "default": true,
          "title": "Indicator State",
          "type": "boolean"
        },
        "staleness_halt_hours": {
          "default": 30,
          "title": "Staleness Halt Hours",
          "type": "integer"
        },
        "fixture_version": {
          "default": "fx-2026-06-v1",
          "title": "Fixture Version",
          "type": "string"
        }
      },
      "title": "DataConfig",
      "type": "object"
    },
    "EODHDConfig": {
      "properties": {
        "api_key": {
          "default": "",
          "format": "password",
          "title": "Api Key",
          "type": "string",
          "writeOnly": true
        },
        "base_url": {
          "default": "https://eodhd.com/api",
          "title": "Base Url",
          "type": "string"
        }
      },
      "title": "EODHDConfig",
      "type": "object"
    },
    "EducationConfig": {
      "properties": {
        "level": {
          "default": "beginner",
          "title": "Level",
          "type": "string"
        },
        "concept_repeat_limit": {
          "default": 3,
          "title": "Concept Repeat Limit",
          "type": "integer"
        }
      },
      "title": "EducationConfig",
      "type": "object"
    },
    "LLMConfig": {
      "properties": {
        "provider": {
          "default": "openrouter",
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "default": "anthropic/claude-sonnet-4",
          "title": "Model",
          "type": "string"
        },
        "base_url": {
          "default": "",
          "title": "Base Url",
          "type": "string"
        },
        "api_key": {
          "default": "",
          "format": "password",
          "title": "Api Key",
          "type": "string",
          "writeOnly": true
        },
        "timeout_s": {
          "default": 30,
          "title": "Timeout S",
          "type": "integer"
        }
      },
      "title": "LLMConfig",
      "type": "object"
    },
    "PaperConfig": {
      "properties": {
        "starting_equity": {
          "default": 100000.0,
          "title": "Starting Equity",
          "type": "number"
        },
        "slippage_bps": {
          "default": 5,
          "title": "Slippage Bps",
          "type": "integer"
        },
        "spread_model": {
          "default": "half_spread_estimate",
          "title": "Spread Model",
          "type": "string"
        }
      },
      "title": "PaperConfig",
      "type": "object"
    },
    "PortfolioConfig": {
      "properties": {
        "max_positions": {
          "default": 8,
          "title": "Max Positions",
          "type": "integer"
        },
        "max_position_pct": {
          "default": 0.15,
          "title": "Max Position Pct",
          "type": "number"
        },
        "max_gross_exposure": {
          "default": 0.8,
          "title": "Max Gross Exposure",
          "type": "number"
        },
        "risk_per_trade_pct": {
          "default": 0.01,
          "title": "Risk Per Trade Pct",
          "type": "number"
        },
        "max_sector_positions": {
          "default": 2,
          "title": "Max Sector Positions",
          "type": "integer"
        }
      },
      "title": "PortfolioConfig",
      "type": "object"
    },
    "RiskConfig": {
      "properties": {
        "stop_atr_mult": {
          "default": 2.0,
          "title": "Stop Atr Mult",
          "type": "number"
        },
        "trail_after_r": {
          "default": 1.0,
          "title": "Trail After R",
          "type": "number"
        },
        "partial_take_at_r": {
          "default": 2.0,
          "title": "Partial Take At R",
          "type": "number"
        },
        "time_stop_days": {
          "default": 30,
          "title": "Time Stop Days",
          "type": "integer"
        },
        "dd_ladder": {
          "default": [
            [
              0.1,
              0.5
            ],
            [
              0.15,
              0.0
            ]
          ],
          "items": {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          "title": "Dd Ladder",
          "type": "array"
        },
        "dd_window_days": {
          "default": 0,
          "title": "Dd Window Days",
          "type": "integer"
        },
        "daily_loss_halt_pct": {
          "default": 0.03,
          "title": "Daily Loss Halt Pct",
          "type": "number"
        }
      },
      "title": "RiskConfig",
      "type": "object"
    },
    "ShadowConfig": {
      "properties": {
        "books": {
          "default": [
            "RULES_ONLY",
            "NO_INSIDER",
            "NO_CROWDING_VETO"
