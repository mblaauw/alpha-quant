# Alpha-Quant configuration overrides
# Copy to .env (or .env.local) and fill in your values.
# These are read by pydantic-settings with ALPHA_QUANT_ prefix.
# Each section.key maps to ALPHA_QUANT_SECTION__KEY (double underscore).

# --- Data ---
ALPHA_QUANT_DATA__MODE=fixture
ALPHA_QUANT_DATA__FIXTURE_VERSION=v1
ALPHA_QUANT_DATA__STALENESS_HALT_HOURS=30

# --- Data providers ---
ALPHA_QUANT_EODHD__API_KEY=
ALPHA_QUANT_ALPACA__API_KEY=
ALPHA_QUANT_ALPACA__SECRET_KEY=
ALPHA_QUANT_ALPACA__PAPER=True

# --- LLM ---
ALPHA_QUANT_LLM__API_KEY=
ALPHA_QUANT_LLM__BASE_URL=https://api.openai.com/v1
ALPHA_QUANT_LLM__MODEL=gpt-4o-mini

# --- Risk ---
ALPHA_QUANT_RISK__STOP_ATR_MULT=2.0
ALPHA_QUANT_RISK__MAX_DRAWDOWN_PCT=15.0

# --- Portfolio ---
ALPHA_QUANT_PORTFOLIO__MAX_POSITIONS=10
ALPHA_QUANT_PORTFOLIO__INITIAL_CAPITAL=100000

# --- Dashboard ---
ALPHA_QUANT_DASHBOARD__REFRESH_SECONDS=60
