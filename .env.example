# Alpha-Quant environment configuration
# Copy to .env and fill in your values.

# Alpha-Lake REST API connection
ALPHA_QUANT_LAKE__MODE=rest
ALPHA_QUANT_LAKE__BASE_URL=http://host.docker.internal:8000
ALPHA_LAKE_API_KEY=

# PostgreSQL connection (default credentials for dev compose stack)
DATABASE_URL=postgresql+psycopg://alpha_quant:alpha_quant_dev@postgres:5432/alpha_quant
