# Local config overrides
#
# Copy this file to config.local.toml (gitignored) and fill in your real secrets.
# Values here override config.toml at runtime. Environment variables
# (ALPHA_QUANT_ prefix) take highest precedence.
#
# Example:
#
# [lake]
# mode = "rest"
# base_url = "http://localhost:8000"
#
# [llm]
# api_key = "your-openrouter-or-openai-key"
